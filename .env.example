# AeroMonitor v2.4 — Environment Variables
# Copy this file to .env and fill in values before running docker-compose

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=secure_pass_change_me

# ---------------------------------------------------------------------------
# Rooktec Portal Credentials (used by the ingestion collector)
# ---------------------------------------------------------------------------
ROOKTEC_URL=https://www.rooktec.in/wmapp
ROOKTEC_USERNAME=smb
ROOKTEC_PASSWORD=wind@smb

# ---------------------------------------------------------------------------
# Ingestion Scheduler
# ---------------------------------------------------------------------------
# How often to collect turbine data (minutes)
COLLECTION_INTERVAL_MINUTES=15

# ---------------------------------------------------------------------------
# FastAPI / CORS
# ---------------------------------------------------------------------------
# Set to specific origins in production, e.g.: https://yourdomain.com
# Use * for development (allows all origins)
CORS_ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
